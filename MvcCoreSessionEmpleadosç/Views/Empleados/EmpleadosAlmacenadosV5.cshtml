@model List<Empleado>
@{
    List<Empleado> empleadosEnSesion = memoryCache.Get<List<Empleado>>("FAVORITOS");
}
<h1>Empleados Almacenados OK</h1>

<p>
    <a asp-controller="Empleados" asp-action="SessionEmpleadosV5">Volver a la lista de empleados</a>
</p>
@if (Context.Session.GetString("ids") == null)
{
    <h1>No existen empleados en sesion</h1>
}
@if (Model != null && Model.Count > 0)
{
    <h2>Empleados almacenados en sesión:</h2>
    <ul>
        @foreach (var empleado in Model)
        {

            <li>Empleado ID:@empleado.emp_no</li>
            <li>Apellido: @empleado.apellido</li>
            <li><a asp-controller="Empleados" asp-action="EmpleadosAlmacenadosV5" asp-route-ideliminar="@empleado.emp_no">Eliminar Session</a></li>

        }
    </ul>
}

else
{
    <h2>No hay empleados almacenados en sesión.</h2>
    <h1>@ViewData["MENSAJE"]</h1>
}